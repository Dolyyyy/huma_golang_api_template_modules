package auth_keycloak

import (
	"context"
	"crypto/tls"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"net/url"
	"strings"
	"time"
)

type introspectionResult struct {
	Active            bool   `json:"active"`
	ExpiresAtUnix     int64  `json:"exp,omitempty"`
	Subject           string `json:"sub,omitempty"`
	Scope             string `json:"scope,omitempty"`
	PreferredUsername string `json:"preferred_username,omitempty"`
	Audience          any    `json:"aud,omitempty"`
}

func introspectToken(ctx context.Context, cfg keycloakConfig, token string) (introspectionResult, error) {
	body, statusCode, err := callIntrospection(ctx, cfg, token)
	if err != nil {
		return introspectionResult{}, err
	}
	if statusCode != http.StatusOK {
		return introspectionResult{}, fmt.Errorf("introspection returned status %d", statusCode)
	}

	var result introspectionResult
	if err := json.Unmarshal(body, &result); err != nil {
		return introspectionResult{}, fmt.Errorf("failed to decode introspection response: %w", err)
	}

	if result.ExpiresAtUnix > 0 && time.Now().Unix() >= result.ExpiresAtUnix {
		result.Active = false
	}

	return result, nil
}

func probeIntrospection(ctx context.Context, cfg keycloakConfig) (bool, string) {
	_, statusCode, err := callIntrospection(ctx, cfg, "__probe_invalid_token__")
	if err != nil {
		return false, err.Error()
	}
	if statusCode >= 500 {
		return false, fmt.Sprintf("upstream status %d", statusCode)
	}

	return true, fmt.Sprintf("upstream status %d", statusCode)
}

func callIntrospection(ctx context.Context, cfg keycloakConfig, token string) ([]byte, int, error) {
	form := url.Values{}
	form.Set("token", token)
	form.Set("client_id", cfg.ClientID)
	form.Set("client_secret", cfg.ClientSecret)

	request, err := http.NewRequestWithContext(ctx, http.MethodPost, cfg.IntrospectionURL, strings.NewReader(form.Encode()))
	if err != nil {
		return nil, 0, err
	}
	request.Header.Set("Content-Type", "application/x-www-form-urlencoded")

	client := &http.Client{
		Timeout: cfg.Timeout,
		Transport: &http.Transport{
			TLSClientConfig: &tls.Config{
				MinVersion:         tls.VersionTLS12,
				InsecureSkipVerify: cfg.SkipTLSVerify,
			},
		},
	}

	response, err := client.Do(request)
	if err != nil {
		return nil, 0, err
	}
	defer response.Body.Close()

	body, err := io.ReadAll(response.Body)
	if err != nil {
		return nil, response.StatusCode, err
	}

	return body, response.StatusCode, nil
}

func audienceAllowed(required string, raw any) bool {
	required = strings.TrimSpace(required)
	if required == "" {
		return true
	}

	switch typed := raw.(type) {
	case string:
		return strings.EqualFold(strings.TrimSpace(typed), required)
	case []any:
		for _, item := range typed {
			text, ok := item.(string)
			if !ok {
				continue
			}
			if strings.EqualFold(strings.TrimSpace(text), required) {
				return true
			}
		}
	}

	return false
}
