package cache_redis

import (
	"context"
	"crypto/tls"
	"errors"
	"fmt"
	"strings"
	"sync"
	"time"

	"github.com/redis/go-redis/v9"
)

type cacheService struct {
	cfg    redisConfig
	client *redis.Client
	local  *localCache
}

type localCache struct {
	mu    sync.RWMutex
	items map[string]localCacheItem
}

type localCacheItem struct {
	Value     string
	ExpiresAt time.Time
}

var (
	serviceOnce sync.Once
	serviceInst *cacheService
	serviceErr  error
)

func sharedService() (*cacheService, error) {
	serviceOnce.Do(func() {
		cfg, err := loadRedisConfig()
		if err != nil {
			serviceErr = err
			return
		}

		options := &redis.Options{
			Addr:         cfg.Address,
			Password:     cfg.Password,
			DB:           cfg.DB,
			DialTimeout:  cfg.ConnectTimeout,
			ReadTimeout:  cfg.ReadTimeout,
			WriteTimeout: cfg.WriteTimeout,
		}
		if cfg.UseTLS {
			options.TLSConfig = &tls.Config{MinVersion: tls.VersionTLS12}
		}

		svc := &cacheService{
			cfg:    cfg,
			client: redis.NewClient(options),
		}
		if cfg.LocalCacheEnabled {
			svc.local = &localCache{items: make(map[string]localCacheItem)}
		}

		serviceInst = svc
	})

	return serviceInst, serviceErr
}

func (s *cacheService) Ping(ctx context.Context) error {
	return s.client.Ping(ctx).Err()
}

func (s *cacheService) Get(ctx context.Context, key string) (string, bool, string, error) {
	trimmedKey := strings.TrimSpace(key)
	if trimmedKey == "" {
		return "", false, "", fmt.Errorf("key is required")
	}

	if s.local != nil {
		if value, ok := s.local.get(trimmedKey); ok {
			return value, true, "memory", nil
		}
	}

	value, err := s.client.Get(ctx, trimmedKey).Result()
	if err != nil {
		if errors.Is(err, redis.Nil) {
			return "", false, "", nil
		}
		return "", false, "", err
	}

	if s.local != nil {
		s.local.set(trimmedKey, value, s.cfg.LocalCacheTTL)
	}

	return value, true, "redis", nil
}

func (s *cacheService) Set(ctx context.Context, key, value string, ttl time.Duration) error {
	trimmedKey := strings.TrimSpace(key)
	if trimmedKey == "" {
		return fmt.Errorf("key is required")
	}

	effectiveTTL := ttl
	if effectiveTTL < 0 {
		return fmt.Errorf("ttl must be >= 0")
	}
	if effectiveTTL == 0 {
		effectiveTTL = s.cfg.DefaultTTL
	}

	if err := s.client.Set(ctx, trimmedKey, value, effectiveTTL).Err(); err != nil {
		return err
	}

	if s.local != nil {
		s.local.set(trimmedKey, value, s.cfg.LocalCacheTTL)
	}

	return nil
}

func (s *cacheService) Del(ctx context.Context, key string) error {
	trimmedKey := strings.TrimSpace(key)
	if trimmedKey == "" {
		return fmt.Errorf("key is required")
	}

	if err := s.client.Del(ctx, trimmedKey).Err(); err != nil {
		return err
	}

	if s.local != nil {
		s.local.del(trimmedKey)
	}

	return nil
}

func (c *localCache) get(key string) (string, bool) {
	now := time.Now()

	c.mu.RLock()
	item, exists := c.items[key]
	c.mu.RUnlock()
	if !exists {
		return "", false
	}

	if !item.ExpiresAt.IsZero() && now.After(item.ExpiresAt) {
		c.mu.Lock()
		delete(c.items, key)
		c.mu.Unlock()
		return "", false
	}

	return item.Value, true
}

func (c *localCache) set(key, value string, ttl time.Duration) {
	var expiresAt time.Time
	if ttl > 0 {
		expiresAt = time.Now().Add(ttl)
	}

	c.mu.Lock()
	c.items[key] = localCacheItem{
		Value:     value,
		ExpiresAt: expiresAt,
	}
	c.mu.Unlock()
}

func (c *localCache) del(key string) {
	c.mu.Lock()
	delete(c.items, key)
	c.mu.Unlock()
}
