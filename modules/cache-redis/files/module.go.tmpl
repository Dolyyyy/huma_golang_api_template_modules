package cache_redis

import (
	"github.com/go-chi/chi/v5"

	"{{ .ProjectModulePath }}/internal/modulekit"
)

func init() {
	modulekit.Register(modulekit.Definition{
		ID:          "cache-redis",
		Name:        "Redis cache",
		Description: "Add Redis cache endpoints with optional in-memory L1 cache.",
		Validate:    validateRedisConfig,
		Routes:      registerRoutes,
	})
}

func registerRoutes(router chi.Router) {
	router.Get("/cache/redis/ping", pingHandler)
	router.Get("/cache/redis/get", getHandler)
	router.Post("/cache/redis/set", setHandler)
	router.Delete("/cache/redis/del", delHandler)
}
