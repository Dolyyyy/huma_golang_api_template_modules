{
  "id": "request-id",
  "name": "Request ID middleware",
  "description": "Inject and propagate request IDs on all HTTP requests.",
  "package": "internal/modules/request_id",
  "defaults": {
    "REQUEST_ID_HEADER": "X-Request-ID"
  },
  "cleanup_env_keys": [
    "REQUEST_ID_HEADER"
  ],
  "files": [
    {
      "source": "files/module.go.tmpl",
      "destination": "internal/modules/request_id/module.go"
    }
  ]
}
